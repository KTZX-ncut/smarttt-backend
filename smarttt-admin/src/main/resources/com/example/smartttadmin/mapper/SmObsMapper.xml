<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.smartttadmin.mapper.SmObsMapper">
    <!--    id: 方法名 resultType：单条记录所封装的类型，全类名-->

    <select id="getSmObsByIDs" resultType="com.example.smartttadmin.pojo.SmObs">
        select * from sm_obs where id in
        <foreach collection="ids" item="id" separator="," open="(" close=")">
            #{id}
        </foreach>
    </select>

</mapper>