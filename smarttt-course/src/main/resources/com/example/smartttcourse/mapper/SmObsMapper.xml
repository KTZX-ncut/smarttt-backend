<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.smartttcourse.mapper.SmObsMapper">

    <!-- List<SmObs> getObsByObsNameAndDeep(@Param("obsname") String obsname, @Param("obsdeep") Long obsdeep, @Param("termid") String termid);-->
    <select id="getObsByObsNameAndDeep" resultType="com.example.smartttcourse.pojo.SmObs">
        SELECT * FROM sm_obs 
        WHERE obsname = #{obsname} 
        AND obsdeep = #{obsdeep}
        AND (termid = #{termid} OR termid = 0)
    </select>
</mapper>
