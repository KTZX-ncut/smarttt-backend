<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.smartttevaluation.mapper.CmKwadictMapper">
    <update id="updateKwadictByID">
        update cm_kwadict
        <!-- 使用set标签，代替update语句中的set关键字 -->
        <set>
            <if test="datavalue != null">
                datavalue=#{datavalue},
            </if>
            <if test="keywordid != null">
                keywordid=#{keywordid},
            </if>
            <if test="abilityid != null">
                abilityid=#{abilityid},
            </if>
        </set>
        where id=#{id}
    </update>

    <delete id="deleteKwadictByIds">
        delete from cm_kwadict where id in
        <foreach item="id" collection="ids" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>