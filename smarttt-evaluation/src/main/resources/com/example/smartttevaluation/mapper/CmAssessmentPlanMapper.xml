<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.smartttevaluation.mapper.CmAssessmentPlanMapper">

    <!--查询表项-->
    <select id="selectAssessmentPlanItems" resultType="com.example.smartttevaluation.pojo.CmAssessmentPlanItem">
        select id,name,s1,s2,s3,s4,s5 from cm_coursetarget where courseid=#{courseid} order by name
    </select>

</mapper>