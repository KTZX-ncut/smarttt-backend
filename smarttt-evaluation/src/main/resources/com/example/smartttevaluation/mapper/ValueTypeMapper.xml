<?xml version="1.0" encoding="utf-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.example.smartttevaluation.mapper.ValueTypeMapper">
    <insert id="create">
        insert into value_type(id,`name`,remark,createtime)
        values (#{id},#{name},#{remark},#{createTime})
    </insert>
    <update id="update">
        update value_type
        <set>
            <if test="name != null and name != '' ">
                `name` = #{name},
            </if>
            <if test="remark != null and remark != '' ">
                remark = #{remark},
            </if>
            createtime = #{createTime}
        </set>
        where id = #{id}
    </update>


    <delete id="delete">
        delete from value_type where id in
        <foreach collection="idList" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>


    <select id="getAllValueType" resultType="com.example.smartttevaluation.dto.ValueTypeDto">
        select id,`name`,remark,createtime from value_type
    </select>
    <select id="getValueTypeByName" resultType="java.lang.Integer">
        select COUNT(*) from value_type where `name` = #{name}
    </select>
    <select id="countById" resultType="java.lang.Integer">
        select COUNT(*) from value_type where id = #{id}
    </select>
</mapper>