<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.smartttevaluation.mapper.CmKeywordsMapper">
    <update id="updateKeywordsByID">
        update cm_keywords
        <!-- 使用set标签，代替update语句中的set关键字 -->
        <set>
            <if test="name != null">
                name=#{name},
            </if>
            <if test="datavalue != null">
                datavalue=#{datavalue},
            </if>
            <if test="importantlevelid != null">
                importantlevelid=#{importantlevelid},
            </if>
            <if test="remark != null">
                remark=#{remark},
            </if>
        </set>
        where id=#{id}
    </update>

    <delete id="deleteKeywordsByIDs">
        delete from cm_keywords where id in
        <foreach item="id" collection="ids" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <select id="getKwaByKeywordsId" resultType="com.example.smartttevaluation.pojo.CmKwadict">
        select * from cm_kwadict where keywordid in
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>
</mapper>