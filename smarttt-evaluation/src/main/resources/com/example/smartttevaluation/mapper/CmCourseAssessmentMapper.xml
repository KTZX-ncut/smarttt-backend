<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.smartttevaluation.mapper.CmCourseAssessmentMapper">
    <delete id="disassociate">
        delete from cm_course_assessment_checkitem_file
        where checkitemId = #{checkitemId}
        and fileId in
        <foreach collection="files" item="file" open="(" separator="," close=")">
            #{file.id}
        </foreach>
    </delete>

    <delete id="deleteStandardScoreByTargetId">
        delete from cm_course_assessment where coursetargetId in
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>