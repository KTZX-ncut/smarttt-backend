<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.smartttevaluation.mapper.CmLinesMapper">
    <delete id="deleteLinesByIds">
        delete from cm_lines where id in
        <foreach item="id" collection="ids" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <delete id="deleteLinesByKwaIds">
        delete from cm_lines where startkwaid in
        <foreach collection="kwaIds" item="kwaId" open="(" separator="," close=")">
            #{kwaId}
        </foreach>
        or endkwaid in
        <foreach collection="kwaIds" item="kwaId" open="(" separator="," close=")">
            #{kwaId}
        </foreach>
    </delete>

    <delete id="deleteLinesByUnitIdAndKwaId">
        delete from cm_lines where (startunitid = #{unitId} or endunitid = #{unitId})
        and (startkwaid in
        <foreach collection="kwaIds" item="kwaId" open="(" separator="," close=")">
            #{kwaId}
        </foreach>
        or endkwaid in
        <foreach collection="kwaIds" item="kwaId" open="(" separator="," close=")">
            #{kwaId}
        </foreach>)
    </delete>
</mapper>