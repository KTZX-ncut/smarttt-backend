<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.smartttevaluation.mapper.CmCoursetargetMapper">
    <update id="updateCoursetargetByID">
        update cm_course_target
        <!-- 使用set标签，代替update语句中的set关键字 -->
        <!-- id, code, name, remark, unitid, courseid, kwaid -->
        <set>
            <if test="code != null" >
                code=#{code},
            </if>
            <if test="name != null">
                name=#{name},
            </if>
            <if test="unitid != null">
                unitid=#{unitid},
            </if>
            <if test="unitname != null">
                unitname=#{unitname},
            </if>
            <if test="courseid != null">
                courseid=#{courseid},
            </if>
            <if test="remark != null">
                remark=#{remark},
            </if>
        </set>
        where id=#{id}
    </update>

    <delete id="deleteCoursetargetByIds">
        delete from cm_course_target where id in
        <foreach item="id" collection="targetIds" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <delete id="deleteKwasByTargetIds">
        delete from cm_course_target_kwa where targetId in
        <foreach collection="targetIds" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

<!--    <insert id="createKwasByTargetIdAndKwaId">-->
<!--        insert into cm_course_target_kwa(kwaId, targetId, obsId)-->
<!--        values-->
<!--        <foreach collection="cmCoursetarget.kwas" item="kwa" separator=",">-->
<!--            (#{kwa.id}, #{cmCoursetarget.id}, #{cmCoursetarget.courseid})-->
<!--        </foreach>-->
<!--    </insert>-->

    <delete id="deleteKwasByTargetIdAndKwaId">
        delete from cm_course_target_kwa where kwaId in
        <foreach collection="cmCoursetarget.kwas" item="kwa" open="(" separator="," close=")">
            #{kwa.id}
        </foreach>
        and obsId = #{cmCoursetarget.courseid} and targetId = #{cmCoursetarget.id}
    </delete>

    <delete id="deleteTargetKwaByKwaIds">
        delete from cm_course_target_kwa where kwaId in
        <foreach collection="kwaIds" item="kwaId" open="(" separator="," close=")">
            #{kwaId}
        </foreach>
    </delete>
</mapper>