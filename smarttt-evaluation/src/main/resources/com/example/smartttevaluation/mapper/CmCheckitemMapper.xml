<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.smartttevaluation.mapper.CmCheckitemMapper">
    <select id="getCmCheckitemByIDs" resultType="com.example.smartttevaluation.pojo.CmCheckitem">
        select * from cm_course_checkitem where id in
        <foreach collection="ids" item="id" separator="," open="(" close=")">
            #{id}
        </foreach>
    </select>
    <delete id="deleteCheckitemByIDs">
        delete from cm_course_checkitem where id in
        <foreach item="id" collection="ids" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>