<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.smartttexam.mapper.PmTestpaperQuestionsMapper">

    <!-- 批量插入试卷-题目关联 -->
    <insert id="batchInsert" parameterType="java.util.List">
        INSERT INTO pm_testpaper_questions (id, paperId, score, libId, sort)
        VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.id}, #{item.paperId}, #{item.score}, #{item.libId}, #{item.sort})
        </foreach>
    </insert>

</mapper>
